# Auth.js v5
AUTH_SECRET=dev-only-secret-change-me
AUTH_TRUST_HOST=true

# Strapi backend base URL (no trailing slash)
STRAPI_URL=http://127.0.0.1:1337

# Pixtrela Strapi API token (create in Strapi admin; grant task + template-task + step).
# Used server-side by the webhook handler only — never expose to the browser.
STRAPI_SYNC_API_TOKEN=

# Legacy RBX (WordPress) — template subtasks by prodId when CRM pedido is imported.
# LEGACY_RBX_URL is the site base URL (no trailing slash); products route is
# `${LEGACY_RBX_URL}/produtos`.
LEGACY_RBX_URL=http://localhost
LEGACY_RBX_TOKEN=

# CRM webhook — sys-rbx-backend POSTs pedido updates to /api/webhooks/crm-pedido.
# Must match PIXTRELA_WEBHOOK_SECRET on CRM Strapi.
CRM_WEBHOOK_SECRET=

# Playwright E2E — copy these into `.env.local` (loaded by playwright.config).
# Manager: create with `npm run seed:e2e` in strapi/ (defaults below).
E2E_MANAGER_LOGIN=e2e-manager
E2E_MANAGER_PASSWORD=PixtrelaE2e1
# Colaborator: any active colaborator user (login + password) in Strapi.
E2E_COLABORATOR_LOGIN=
E2E_COLABORATOR_PASSWORD=
# Kiosk: any active kiosk role user (login + password) in Strapi.
E2E_KIOSK_LOGIN=
E2E_KIOSK_PASSWORD=
